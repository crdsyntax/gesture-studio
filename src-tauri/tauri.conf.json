{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Gesture Studio",
  "version": "0.1.0",
  "identifier": "com.gesturestudio.app",
  "build": {
    "frontendDist": "../frontend/dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "bun run frontend:dev",
    "beforeBuildCommand": "bun run frontend:build"
  },
  "app": {
    "windows": [
      {
        "title": "Gesture Studio",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png"
    ]
  }
}
